# ── LLM provider (pick one) ──────────────────────────────────────────
# Anthropic (primary).  Supply a key to enable LLM-powered extraction
# and report synthesis.  Without it the system falls back to heuristics.
ANTHROPIC_API_KEY=
ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-20250414
ANTHROPIC_REPORT_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=              # optional, leave blank for default

# Ollama (alternative local LLM).  Uncomment and set a model name.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=mistral

# ── Operational knobs ────────────────────────────────────────────────
DEFAULT_MAX_ARTICLES=5
REQUEST_TIMEOUT_SECONDS=20
MAX_LLM_CHARS_PER_ARTICLE=8000
USER_AGENT=cyber-threat-intel-agent/0.1 (+https://example.local)
